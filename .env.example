# RabbitMQ (connects to production RabbitMQ in all environments)
RABBITMQ_URL=amqp://user:password@your-rabbitmq-host:5672
RABBITMQ_QUEUES=materny-bot-ai.messages.upsert
PROCESSED_MESSAGES_QUEUE=materny-bot-ai.messages.processed
OUTGOING_MESSAGES_QUEUE=materny-bot-ai.messages.outgoing

# Message Processing
MESSAGE_CONVERSATION_CONCAT_WINDOW=15
MESSAGE_MAX_RETRY_COUNT=3
OUTGOING_TYPING_DELAY_MS_PER_CHAR=35

# Audio Transcription (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_LANGUAGE=pt

# Evolution API (outgoing WhatsApp messages)
EVOLUTION_API_URL=https://evo.example.com
EVOLUTION_API_KEY=your-evolution-api-key

# Rails
SECRET_KEY_BASE=generate-with-bin/rails-secret
RAILS_MAX_THREADS=5
